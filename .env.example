# === Apple Pass Identity ===
PASS_TYPE_ID=pass.com.yourname.fancard
TEAM_ID=YOUR_TEAM_ID

# === Signing Certs ===
# Option A: file paths (local dev)
SIGNER_CERT=certs/signerCert.pem
SIGNER_KEY=certs/signerKey.pem
SIGNER_PASSPHRASE=
WWDR_CERT=certs/wwdr.pem

# Option B: base64-encoded (Railway / Docker) — takes priority over file paths
# SIGNER_CERT_B64=
# SIGNER_KEY_B64=
# WWDR_CERT_B64=
# APNS_KEY_B64=

# === APNs Push (token-based) ===
APNS_KEY_PATH=certs/APNsAuthKey.p8
APNS_KEY_ID=YOUR_KEY_ID
APNS_HOST=https://api.push.apple.com

# === Server ===
PORT=3000
WEB_SERVICE_URL=https://your-app.up.railway.app

# === Fan Page ===
ARTIST_NAME=Your Artist Name
